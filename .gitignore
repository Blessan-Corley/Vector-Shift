# ==============================================================================
# PipelineForge Monorepo .gitignore
# Co-existing FastAPI Backend & Vite-React Frontend
# ==============================================================================

# ------------------------------------------------------------------------------
# System & Editor Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# IDEs and Editors
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ------------------------------------------------------------------------------
# Frontend (Node / Vite / React)
# ------------------------------------------------------------------------------
# Dependency directory
frontend/node_modules/
node_modules/

# Production / Build outputs
frontend/dist/
frontend/build/
dist/
build/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Testing
frontend/coverage/
coverage/
.nyc_output/

# Environment files (sensitive data)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Yarn/pnpm specific
.yarn/
.pnp.*
.pnp

# Vite specific
.vite/

# ------------------------------------------------------------------------------
# Backend (Python / FastAPI)
# ------------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
backend/__pycache__/

# C extensions
*.so

# Distribution / packaging
.Python
backend/build/
backend/dist/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
.venv/
venv/
ENV/
env/
backend/.venv/
backend/venv/
backend/env/
custom_venv/

# Pip env / poetry / pipenv
Pipfile.lock
poetry.lock
.pdm.toml
.pdm-plugins/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
backend/.pytest_cache/

# Translation files
*.mo
*.pot

# Django / Flask / database files (if any sqlite is added later)
*.db
*.sqlite3

# ------------------------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------------------------
# Screen recording and PDF files
*.mp4
*.mov
*.avi
*.mkv
screen_recording_script.md
*.pdf
